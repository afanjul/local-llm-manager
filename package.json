{
  "name": "local-llm-manager",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "local-llm-manager": "./src/index.tsx"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch src/index.tsx",
    "build": "bun build --compile --target=bun-darwin-arm64 ./src/index.tsx --outfile local-llm-manager && codesign --sign - --force --entitlements entitlements.plist local-llm-manager"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "react-devtools-core": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "typescript": "^5.7.2"
  }
}
